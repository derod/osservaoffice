# === OSERVA OFFICE — Environment Variables ===
# Copy this file to .env for local development. Never commit .env.

# ── Core (required in production) ─────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Set to "production" on Railway. Leave blank or "development" locally.
FLASK_ENV=development

# ── Database ───────────────────────────────────────────────────────────────────
# Local SQLite path (relative to project root). Ignored when DATABASE_URL is set.
DATABASE_PATH=oserva.db
# PostgreSQL URL — set automatically by Railway when you add a Postgres service.
# When DATABASE_URL is present the app uses PostgreSQL; otherwise SQLite is used.
# DATA MIGRATION: after setting DATABASE_URL run once:
#   DATABASE_URL=... DATABASE_PATH=osserva.db python migrate_to_pg.py
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── File uploads ──────────────────────────────────────────────────────────────
# Directory for uploaded files (relative to project root).
# WARNING: on Railway this path is ephemeral. Use a volume or object storage.
UPLOAD_DIR=app/static/uploads
MAX_UPLOAD_SIZE_MB=20

# ── Session / auth ────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Super-admin bootstrap (optional) ─────────────────────────────────────────
# If set, an admin account is created/upgraded on startup (idempotent).
# SUPER_ADMIN_EMAIL=admin@example.com
# SUPER_ADMIN_PASSWORD=changeme
# SUPER_ADMIN_NAME=Admin User

# ── Multi-tenant default organization ────────────────────────────────────────
# On first boot a "Default Organization" is created automatically.
# Set this to name it after your first customer / firm on initial deploy.
# DEFAULT_ORG_NAME=Acme Law LLP

# ── Gmail integration (optional) ─────────────────────────────────────────────
# Absolute paths to the OAuth credential files inside the container.
# On Railway, mount a volume at /data/secrets and upload the files there.
# GMAIL_CREDENTIALS_PATH=/data/secrets/gmail_credentials.json
# GMAIL_TOKEN_PATH=/data/secrets/gmail_token.json

# ── OpenAI (optional — legal consultant feature) ─────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Server (Railway sets PORT automatically) ──────────────────────────────────
PORT=5000
