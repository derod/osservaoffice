{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flask: Run Development Server",
      "type": "python",
      "request": "launch",
      "module": "flask",
      "env": {
        "FLASK_APP": "run.py",
        "FLASK_DEBUG": "1"
      },
      "args": [
        "run",
        "--host=0.0.0.0",
        "--port=5000"
      ],
      "jinja": true,
      "justMyCode": true
    },
    {
      "name": "Python: Seed Database",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/seed.py",
      "console": "integratedTerminal"
    }
  ]
}
